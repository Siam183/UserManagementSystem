@model UserManagement.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<!-- IMPORTANT: Registration page for new users -->

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">

            <div class="card shadow">

                <div class="card-header text-center">
                    <h3>User Management</h3>
                    <p class="mb-0">Create a new account</p>
                </div>

                <div class="card-body">

                    <!-- NOTE: Display validation errors -->
                    <div asp-validation-summary="All"
                         class="text-danger mb-3">
                    </div>

                    <form asp-action="Register" method="post">

                        <!-- IMPORTANT: User full name -->
                        <div class="mb-3">
                            <label asp-for="Name"
                                   class="form-label">
                            </label>

                            <input asp-for="Name"
                                   class="form-control"
                                   placeholder="Enter your name" />

                            <span asp-validation-for="Name"
                                  class="text-danger">
                            </span>
                        </div>

                        <!-- IMPORTANT: User email address -->
                        <div class="mb-3">
                            <label asp-for="Email"
                                   class="form-label">
                            </label>

                            <input asp-for="Email"
                                   class="form-control"
                                   placeholder="Enter your email" />

                            <span asp-validation-for="Email"
                                  class="text-danger">
                            </span>
                        </div>

                        <!-- IMPORTANT: User password -->
                        <div class="mb-3">
                            <label asp-for="Password"
                                   class="form-label">
                            </label>

                            <input asp-for="Password"
                                   type="password"
                                   class="form-control"
                                   placeholder="Enter your password" />

                            <span asp-validation-for="Password"
                                  class="text-danger">
                            </span>
                        </div>

                        <button type="submit"
                                class="btn btn-success w-100">
                            Register
                        </button>

                    </form>

                    <hr />

                    <!-- NOTA BENE: Existing users can login -->
                    <div class="text-center">
                        <a asp-action="Login">
                            Already have an account? Login
                        </a>
                    </div>

                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}